rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - displayName: string (optional)
    //   - email: string (optional)
    //   - photoURL: string (optional)
    //   - goal: string (optional, enum: 'Loss', 'Gain', 'Maintain')
    //   - age: number (optional)
    //   - weight: number (optional)
    //   - height: number (optional)
    //   - targetCalories: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: meals
    // Document ID: {mealId}
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - type: string (required, enum: 'Breakfast', 'Lunch', 'Dinner', 'Snack')
    //   - name: string (required)
    //   - calories: number (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - createdAt: timestamp (required)
    //
    // Collection: weightLogs
    // Document ID: {logId}
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - weight: number (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function userIdUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function userIdNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function isValidOptionalNumber(field, min, max) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is number &&
              request.resource.data[field] >= min &&
              request.resource.data[field] <= max);
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser() {
      return hasRequiredFields(['uid', 'createdAt']) &&
             request.resource.data.uid is string &&
             request.resource.data.createdAt is timestamp &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('email', 0, 100) &&
             isValidOptionalString('photoURL', 0, 500) &&
             (!( 'goal' in request.resource.data ) || request.resource.data.goal in ['Loss', 'Gain', 'Maintain']) &&
             isValidOptionalNumber('age', 0, 150) &&
             isValidOptionalNumber('weight', 0, 1000) &&
             isValidOptionalNumber('height', 0, 300) &&
             isValidOptionalNumber('targetCalories', 0, 10000);
    }
    
    function isValidMeal() {
      return hasRequiredFields(['userId', 'type', 'name', 'calories', 'date', 'createdAt']) &&
             request.resource.data.userId is string &&
             request.resource.data.type in ['Breakfast', 'Lunch', 'Dinner', 'Snack'] &&
             isValidStringLength('name', 1, 100) &&
             request.resource.data.calories is number &&
             request.resource.data.calories >= 0 &&
             request.resource.data.calories <= 5000 &&
             isValidStringLength('date', 10, 10) &&
             request.resource.data.createdAt is timestamp;
    }
    
    function isValidWeightLog() {
      return hasRequiredFields(['userId', 'weight', 'date', 'createdAt']) &&
             request.resource.data.userId is string &&
             request.resource.data.weight is number &&
             request.resource.data.weight > 0 &&
             request.resource.data.weight <= 1000 &&
             isValidStringLength('date', 10, 10) &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId);
    }
    
    match /meals/{mealId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidMeal() && userIdUnchanged();
      allow update: if isDocOwner() && isValidMeal() && userIdNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
    
    match /weightLogs/{logId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidWeightLog() && userIdUnchanged();
      allow update: if isDocOwner() && isValidWeightLog() && userIdNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
